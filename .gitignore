# .gitignore — monorepo root (Java/Spring services + Angular web)
# Patterns have NO leading "/", so they match at any depth:
# services/*/target/, web/node_modules/, web/dist/, etc.

# ============================================================
# Java / Spring Boot   (Maven: target/ · Gradle: build/ + .gradle/)
# ============================================================

# Build output & IDE compile dirs
target/
build/
.gradle/
out/

# Compiled classes, logs, JVM crash dumps
*.class
*.log
logs/
hs_err_pid*
replay_pid*

# Local overrides & secrets — never commit real credentials
*-local.properties
*-local.yml
*-local.yaml
application-secret*.properties
application-secret*.yml

# Local dev databases (H2)
*.mv.db
*.trace.db

# NOTE: wrapper JARs are committed on purpose —
#   gradle/wrapper/gradle-wrapper.jar and .mvn/wrapper/maven-wrapper.jar —
# so ./gradlew and ./mvnw work right after cloning.
# That is why there is deliberately NO blanket "*.jar" rule here.

# ============================================================
# Angular / Node   (web/)
# ============================================================
node_modules/
dist/
tmp/
out-tsc/
.angular/cache/
coverage/
*.tsbuildinfo
.eslintcache
npm-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files (commit a .env.example template instead)
.env
.env.*
!.env.example

# ============================================================
# IDEs & editors
# ============================================================

# IntelliJ IDEA
.idea/
*.iml
*.ipr
*.iws

# Eclipse
.classpath
.project
.settings/

# VS Code (keep shared settings if you add them)
.vscode/*
!.vscode/settings.json
!.vscode/launch.json
!.vscode/extensions.json

# ============================================================
# OS junk
# ============================================================
.DS_Store
._*
Thumbs.db
Desktop.ini
*~